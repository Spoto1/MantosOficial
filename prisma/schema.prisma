generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum ShippingStatus {
  PENDING
  READY_TO_SHIP
  IN_TRANSIT
  DELIVERED
  RETURNED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum ContactLeadStatus {
  NEW
  IN_REVIEW
  REPLIED
  ARCHIVED
}

enum NewsletterLeadStatus {
  ACTIVE
  ARCHIVED
  UNSUBSCRIBED
}

enum LeadType {
  CONTACT
  NEWSLETTER
}

enum LeadStatus {
  NEW
  IN_CONTACT
  QUALIFIED
  CONVERTED
  ARCHIVED
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  EDITOR
  MARKETING
}

enum AdminUserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum CampaignType {
  HERO
  SECONDARY_BANNER
  PROMO_BAR
  PROMO_CARD
  CATEGORY_AD
  POPUP
}

enum CampaignPlacement {
  HOME_HERO
  HOME_SECONDARY
  SITE_TOP
  BELOW_CATEGORIES
  COLLECTION_PAGE
  PRODUCT_PAGE
  GLOBAL_BAR
  NEWSLETTER_SECTION
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  SCHEDULED
  PAUSED
  ARCHIVED
}

enum AssetKind {
  GENERAL
  CAMPAIGN_IMAGE
}

enum ActivityEntityType {
  PRODUCT
  CAMPAIGN
  LEAD
  CONTACT
  ADMIN
  SESSION
  UPLOAD
  NEWSLETTER
  ORDER
  KANBAN_TASK
}

enum KanbanTaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
}

enum KanbanTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum KanbanTaskType {
  DESIGN
  FRONTEND
  BACKEND
  ADMIN
  CHECKOUT
  AUTH
  CAMPAIGNS
  CONTENT
  INFRA
  BUG
  POLISH
  SECURITY
  OPS
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  products    Product[]
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Collection {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  products    Product[]
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Size {
  id        String           @id @default(cuid())
  label     String           @unique
  sortOrder Int
  variants  ProductVariant[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Product {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  sku              String           @unique
  shortDescription String
  description      String           @db.Text
  price            Decimal          @db.Decimal(10, 2)
  compareAtPrice   Decimal?         @db.Decimal(10, 2)
  stock            Int
  country          String
  season           String
  type             String
  fit              String
  material         String
  badgeLabel       String?
  accentFrom       String
  accentVia        String
  accentTo         String
  primaryHex       String
  secondaryHex     String
  details          String[]
  highlights       String[]
  isRetro          Boolean          @default(false)
  isFeatured       Boolean          @default(false)
  isNew            Boolean          @default(false)
  isBestSeller     Boolean          @default(false)
  isActive         Boolean          @default(true)
  categoryId       String
  collectionId     String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  category         Category         @relation(fields: [categoryId], references: [id])
  collection       Collection       @relation(fields: [collectionId], references: [id])
  images           ProductImage[]
  variants         ProductVariant[]
  favorites        Favorite[]
  orderItems       OrderItem[]
  campaigns        Campaign[]

  @@index([collectionId, isActive])
  @@index([categoryId, isActive])
  @@index([isFeatured, isActive])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  sizeId     String
  colorName  String
  sku        String      @unique
  stock      Int
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       Size        @relation(fields: [sizeId], references: [id])
  orderItems OrderItem[]

  @@unique([productId, sizeId, colorName])
  @@index([productId, isActive])
}

model Customer {
  id               String            @id @default(cuid())
  email            String            @unique
  firstName        String
  lastName         String?
  passwordHash     String?
  phone            String?
  document         String?
  acceptsMarketing Boolean           @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  addresses        Address[]
  orders           Order[]
  favorites        Favorite[]
  sessions         CustomerSession[]
}

model CustomerSession {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  userAgent  String?
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, expiresAt])
  @@index([expiresAt])
}

model Address {
  id            String    @id @default(cuid())
  customerId    String?
  label         String?
  recipientName String
  line1         String
  line2         String?
  city          String
  state         String
  postalCode    String
  country       String
  phone         String?
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orders        Order[]

  @@index([customerId])
}

model Order {
  id                   String         @id @default(cuid())
  number               String         @unique
  externalReference    String?        @unique
  customerId           String?
  addressId            String?
  couponId             String?
  status               OrderStatus    @default(PENDING)
  paymentStatus        PaymentStatus  @default(PENDING)
  shippingStatus       ShippingStatus @default(PENDING)
  paymentProvider      String         @default("stripe")
  paymentMethod        String         @default("checkout_session")
  paymentPreferenceId  String?
  paymentId            String?
  merchantOrderId      String?
  paymentStatusDetail  String?
  checkoutUrl          String?
  customerName         String
  customerEmail        String
  customerPhone        String
  customerDocument     String?
  shippingMethod       String
  subtotal             Decimal        @db.Decimal(10, 2)
  discountAmount       Decimal        @default(0) @db.Decimal(10, 2)
  shippingAmount       Decimal        @default(0) @db.Decimal(10, 2)
  total                Decimal        @db.Decimal(10, 2)
  paidAt               DateTime?
  couponRedeemedAt     DateTime?
  inventoryCommittedAt DateTime?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  customer             Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  address              Address?       @relation(fields: [addressId], references: [id], onDelete: SetNull)
  coupon               Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                OrderItem[]
  webhookEvents        WebhookEvent[]

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  productName String
  productSlug String
  sku         String
  unitPrice   Decimal         @db.Decimal(10, 2)
  quantity    Int
  sizeLabel   String
  colorName   String
  imageUrl    String
  createdAt   DateTime        @default(now())
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Coupon {
  id                 String     @id @default(cuid())
  code               String     @unique
  type               CouponType
  value              Decimal    @db.Decimal(10, 2)
  minimumOrderAmount Decimal?   @db.Decimal(10, 2)
  usageLimit         Int?
  usageCount         Int        @default(0)
  isActive           Boolean    @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  orders             Order[]
}

model NewsletterLead {
  id            String               @id @default(cuid())
  email         String               @unique
  source        String               @default("footer")
  status        NewsletterLeadStatus @default(ACTIVE)
  internalNotes String?              @db.Text
  lead          Lead?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model ContactLead {
  id            String            @id @default(cuid())
  name          String
  email         String
  phone         String?
  subject       String
  message       String            @db.Text
  status        ContactLeadStatus @default(NEW)
  internalNotes String?           @db.Text
  lead          Lead?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, createdAt])
}

model Lead {
  id               String          @id @default(cuid())
  type             LeadType
  source           String
  origin           String
  name             String?
  email            String
  phone            String?
  message          String?         @db.Text
  context          String?         @db.Text
  status           LeadStatus      @default(NEW)
  internalNotes    String?         @db.Text
  newsletterLeadId String?         @unique
  contactLeadId    String?         @unique
  newsletterLead   NewsletterLead? @relation(fields: [newsletterLeadId], references: [id], onDelete: SetNull)
  contactLead      ContactLead?    @relation(fields: [contactLeadId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([email])
}

model AdminUser {
  id                  String          @id @default(cuid())
  name                String
  email               String          @unique
  passwordHash        String?
  role                AdminRole       @default(ADMIN)
  status              AdminUserStatus @default(ACTIVE)
  lastLoginAt         DateTime?
  uploadedAssets      MediaAsset[]    @relation("AdminUploadedAssets")
  createdCampaigns    Campaign[]      @relation("CampaignCreatedBy")
  updatedCampaigns    Campaign[]      @relation("CampaignUpdatedBy")
  assignedKanbanTasks KanbanTask[]    @relation("KanbanTaskAssignee")
  archivedKanbanTasks KanbanTask[]    @relation("KanbanTaskArchivedBy")
  createdKanbanTasks  KanbanTask[]    @relation("KanbanTaskCreatedBy")
  updatedKanbanTasks  KanbanTask[]    @relation("KanbanTaskUpdatedBy")
  kanbanTaskComments  KanbanTaskComment[] @relation("KanbanTaskCommentAuthor")
  activityLogs        ActivityLog[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model MediaAsset {
  id               String     @id @default(cuid())
  label            String
  originalName     String
  fileName         String     @unique
  mimeType         String
  sizeBytes        Int
  url              String     @unique
  storageProvider  String     @default("local-public")
  storageKey       String?
  kind             AssetKind  @default(GENERAL)
  uploadedById     String?
  uploadedBy       AdminUser? @relation("AdminUploadedAssets", fields: [uploadedById], references: [id], onDelete: SetNull)
  desktopCampaigns Campaign[] @relation("CampaignDesktopAsset")
  mobileCampaigns  Campaign[] @relation("CampaignMobileAsset")
  cardCampaigns    Campaign[] @relation("CampaignCardAsset")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([kind, createdAt])
}

model Campaign {
  id              String            @id @default(cuid())
  internalTitle   String
  slug            String            @unique
  type            CampaignType
  placement       CampaignPlacement
  status          CampaignStatus    @default(DRAFT)
  publicTitle     String
  publicSubtitle  String?
  description     String?           @db.Text
  ctaLabel        String?
  ctaLink         String?
  desktopImageUrl String?
  mobileImageUrl  String?
  cardImageUrl    String?
  desktopAssetId  String?
  mobileAssetId   String?
  cardAssetId     String?
  position        Int               @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean           @default(true)
  priority        Int               @default(0)
  accentColor     String?
  isPrimary       Boolean           @default(false)
  collectionId    String?
  categoryId      String?
  productId       String?
  createdById     String?
  updatedById     String?
  desktopAsset    MediaAsset?       @relation("CampaignDesktopAsset", fields: [desktopAssetId], references: [id], onDelete: SetNull)
  mobileAsset     MediaAsset?       @relation("CampaignMobileAsset", fields: [mobileAssetId], references: [id], onDelete: SetNull)
  cardAsset       MediaAsset?       @relation("CampaignCardAsset", fields: [cardAssetId], references: [id], onDelete: SetNull)
  collection      Collection?       @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  category        Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product         Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdBy       AdminUser?        @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       AdminUser?        @relation("CampaignUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([placement, status, isActive])
  @@index([startsAt, endsAt])
  @@index([priority, position])
}

model ActivityLog {
  id          String             @id @default(cuid())
  type        String
  entityType  ActivityEntityType
  entityId    String?
  actorId     String?
  actorName   String?
  actorEmail  String?
  description String
  metadata    Json?
  actor       AdminUser?         @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())

  @@index([entityType, createdAt])
  @@index([createdAt])
}

model KanbanTask {
  id             String                    @id @default(cuid())
  title          String
  description    String                    @db.Text
  notes          String?                   @db.Text
  status         KanbanTaskStatus          @default(BACKLOG)
  priority       KanbanTaskPriority        @default(MEDIUM)
  type           KanbanTaskType            @default(BACKEND)
  sortOrder      Int                       @default(0)
  dueDate        DateTime?
  assigneeId     String?
  createdById    String?
  updatedById    String?
  isArchived     Boolean                   @default(false)
  archivedAt     DateTime?
  archivedById   String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  assignee       AdminUser?                @relation("KanbanTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  archivedBy     AdminUser?                @relation("KanbanTaskArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  createdBy      AdminUser?                @relation("KanbanTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      AdminUser?                @relation("KanbanTaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  checklistItems KanbanTaskChecklistItem[]
  comments       KanbanTaskComment[]

  @@index([isArchived, status, sortOrder])
  @@index([archivedAt])
  @@index([archivedById])
  @@index([priority, updatedAt])
  @@index([type, updatedAt])
  @@index([assigneeId, status])
  @@index([dueDate])
}

model KanbanTaskChecklistItem {
  id        String     @id @default(cuid())
  taskId    String
  label     String
  isDone    Boolean    @default(false)
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  task      KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
}

model KanbanTaskComment {
  id          String     @id @default(cuid())
  taskId       String
  authorId     String?
  authorName   String?
  authorEmail  String?
  body         String     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  task         KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author       AdminUser? @relation("KanbanTaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([authorId, createdAt])
}

model Favorite {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([productId])
}

model WebhookEvent {
  id                String    @id @default(cuid())
  provider          String
  topic             String
  action            String?
  resourceId        String?
  dedupeKey         String    @unique
  requestId         String?
  signatureVerified Boolean   @default(false)
  payload           Json
  processedAt       DateTime?
  orderId           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  order             Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([provider, topic, resourceId])
  @@index([orderId, createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  scope       String
  identifier  String
  windowStart DateTime
  expiresAt   DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scope, identifier, windowStart])
  @@index([scope, identifier, expiresAt])
  @@index([expiresAt])
}
