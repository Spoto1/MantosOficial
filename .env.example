DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mantos_oficial?schema=public"
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"
ENABLE_ADMIN_BOOTSTRAP="false"
# Em desenvolvimento local, deixe vazio para o runtime usar a origem ativa do preview.
# Em produção, defina a URL pública real do storefront.
# Exemplo: https://mantosoficial.com.br
# Se preencher uma, preencha as duas com a mesma origem.
APP_URL=""
NEXT_PUBLIC_APP_URL=""
# Opcional para self-hosted/CI de deploy: habilite a validação rígida da URL pública.
# ENFORCE_PUBLIC_APP_URL="true"
# Libera o fluxo guiado local apenas fora de produção e somente quando Stripe ainda nao estiver configurado.
# Mantenha desabilitado por padrao e habilite manualmente apenas no ambiente local.
# Nao use esta flag como substituto do checkout real.
ALLOW_LOCAL_DEMO_CHECKOUT="false"
# Stripe e o gateway definitivo da loja.
# Preencha sempre com as chaves da conta Stripe correta do projeto.
# STRIPE_SECRET_KEY e NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY precisam ser da mesma modalidade:
# ambas test ou ambas live.
# O webhook publicado deve apontar para /api/webhooks/stripe no mesmo ambiente.
# Use o segredo do endpoint no formato whsec_... e mantenha um por ambiente.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Opcional: limita meios do Stripe Checkout por ambiente. Ex.: card,pix
STRIPE_PAYMENT_METHOD_TYPES=""
STORAGE_DRIVER="local"
STORAGE_PUBLIC_BASE_URL=""
# Exemplo: cdn.mantosoficial.com.br,imagedelivery.net
NEXT_IMAGE_REMOTE_HOSTS=""
